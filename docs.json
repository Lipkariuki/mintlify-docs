{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Smithsons Logistics Documentation",
  "colors": {
    "primary": "#7C3AED",
    "light": "#A855F7",
    "dark": "#5B21B6"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Smithsons Logistics",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "smithsons/introduction",
              "smithsons/getting-started",
              "smithsons/authentication"
            ]
          },
          {
            "group": "Operational Guides",
            "pages": [
              "smithsons/api/orders",
              "smithsons/api/trips",
              "smithsons/api/expenses",
              "smithsons/api/users"
            ]
          },
          {
            "group": "API Reference",
            "openapi": {
              "source": "https://smithsons-logistics.onrender.com/openapi.json"
            }
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Smithsons Dashboard",
          "href": "https://smithsons-logistics-frontend.onrender.com",
          "icon": "truck"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "API Support",
        "href": "mailto:support@smithsons.co.ke"
      }
    ],
    "primary": {
