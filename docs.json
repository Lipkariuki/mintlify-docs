{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Smithsons Logistics Documentation",
  "colors": {
    "primary": "#0F172A",
    "light": "#1E293B",
    "dark": "#020617"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "development"
            ]
          },
          {
            "group": "Customization",
            "pages": [
              "essentials/settings",
              "essentials/navigation"
            ]
          },
          {
            "group": "Writing content",
            "pages": [
              "essentials/markdown",
              "essentials/code",
              "essentials/images",
              "essentials/reusable-snippets"
            ]
          },
          {
            "group": "AI tools",
            "pages": [
              "ai-tools/cursor",
              "ai-tools/claude-code",
              "ai-tools/windsurf"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "API documentation",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Endpoint examples",
            "pages": [
              "api-reference/endpoint/get",
              "api-reference/endpoint/create",
              "api-reference/endpoint/delete",
              "api-reference/endpoint/webhook"
            ]
          }
        ]
      },
      {
        "tab": "Smithsons Logistics",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "smithsons/introduction",
              "smithsons/getting-started",
              "smithsons/authentication"
            ]
          },
          {
            "group": "API Reference",
            "pages": [
              "smithsons/api/orders",
              "smithsons/api/trips",
              "smithsons/api/expenses",
              "smithsons/api/users"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Smithsons Dashboard",
          "href": "https://smithsons-logistics-frontend.onrender.com",
          "icon": "box"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@smithsons.co.ke"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Admin Dashboard",
      "href": "https://smithsons-logistics-frontend.onrender.com/admin/orders"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/Lipkariuki"
    }
  }
}